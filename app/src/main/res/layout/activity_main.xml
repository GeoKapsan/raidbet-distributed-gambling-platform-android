<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="32dp"
            android:paddingBottom="32dp">

            <!-- Top Guideline for Logo -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.08" />

            <!-- Logo Section -->
            <LinearLayout
                android:id="@+id/logoLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/guideline_top">

                <LinearLayout
                    android:layout_width="6dp"
                    android:layout_height="52dp"
                    android:orientation="vertical">
                    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:background="@color/accent_red" />
                    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:background="@color/accent_yellow" />
                    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:background="@color/accent_green" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.2"
                        android:lineHeight="28dp"
                        android:text="RAID"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.2"
                        android:lineHeight="28dp"
                        android:text="BET"
                        android:textColor="@color/accent_red"
                        android:textSize="28sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Main Content Area - Distributed using bias -->
            <LinearLayout
                android:id="@+id/contentArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toTopOf="@+id/footerLayout"
                app:layout_constraintTop_toBottomOf="@id/logoLayout"
                app:layout_constraintVertical_bias="0.45">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk_medium"
                    android:text="@string/welcome_title"
                    android:textColor="@color/text_primary"
                    android:textSize="36sp" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/space_grotesk_regular"
                    android:text="@string/welcome_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/accentLine"
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="24dp"
                    android:background="@color/accent_red" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUsername"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="56dp"
                    android:hint="@string/hint_username"
                    android:textColorHint="@color/text_secondary"
                    app:boxBackgroundColor="@color/surface_variant"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="@color/input_stroke_selector"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="2dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:fontFamily="@font/space_grotesk_medium"
                        android:inputType="text"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="@color/accent_red"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:letterSpacing="0.05"
                    android:text="@string/btn_sign_in"
                    android:textColor="@color/on_accent"
                    android:textSize="16sp"
                    app:cornerRadius="18dp"
                    app:elevation="4dp" />

            </LinearLayout>

            <!-- Footer decorative element -->
            <LinearLayout
                android:id="@+id/footerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                app:layout_constraintBottom_toBottomOf="parent">

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:background="@color/surface_variant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:fontFamily="@font/space_grotesk_regular"
                    android:text="@string/footer_text"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:background="@color/surface_variant" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
