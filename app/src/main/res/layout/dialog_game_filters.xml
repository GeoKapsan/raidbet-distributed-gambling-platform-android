<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="28dp"
    app:cardElevation="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="32dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FILTER GAMES"
            android:fontFamily="@font/space_grotesk_bold"
            android:letterSpacing="0.15"
            android:textSize="11sp"
            android:textColor="@color/accent_blue"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find your game"
            android:fontFamily="@font/space_grotesk_medium"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="16dp"
            android:background="@color/accent_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk Level"
            android:fontFamily="@font/space_grotesk_medium"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupRisk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRiskAny"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Any"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRiskLow"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢  Low" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRiskMedium"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟡  Medium" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRiskHigh"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔴  High" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Betting Category"
            android:fontFamily="@font/space_grotesk_medium"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCatAny"
                style="@style/FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Any"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCatLow"
                style="@style/FilterChipYellow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCatMedium"
                style="@style/FilterChipYellow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$$" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCatHigh"
                style="@style/FilterChipYellow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$$$" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minimum Rating"
            android:fontFamily="@font/space_grotesk_medium"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/layoutStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/star1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="1 star"
                app:srcCompat="@drawable/ic_star_outline"
                app:tint="@color/accent_yellow" />

            <ImageButton
                android:id="@+id/star2"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="2 stars"
                app:srcCompat="@drawable/ic_star_outline"
                app:tint="@color/accent_yellow" />

            <ImageButton
                android:id="@+id/star3"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="3 stars"
                app:srcCompat="@drawable/ic_star_outline"
                app:tint="@color/accent_yellow" />

            <ImageButton
                android:id="@+id/star4"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="4 stars"
                app:srcCompat="@drawable/ic_star_outline"
                app:tint="@color/accent_yellow" />

            <ImageButton
                android:id="@+id/star5"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="5 stars"
                app:srcCompat="@drawable/ic_star_outline"
                app:tint="@color/accent_yellow" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetFilters"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Reset"
                android:fontFamily="@font/space_grotesk_medium"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplyFilters"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Apply Filters"
                android:fontFamily="@font/space_grotesk_bold"
                android:textSize="15sp"
                android:textColor="@color/on_accent"
                android:backgroundTint="@color/accent_blue"
                app:cornerRadius="16dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
