<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="28dp"
    app:cardElevation="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="32dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADD FUNDS"
            android:fontFamily="@font/space_grotesk_bold"
            android:letterSpacing="0.15"
            android:textSize="11sp"
            android:textColor="@color/accent_green"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change your balance"
            android:fontFamily="@font/space_grotesk_medium"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="16dp"
            android:background="@color/accent_green" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_balance_row"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:srcCompat="@drawable/ic_wallet"
                app:tint="@color/text_secondary"
                android:contentDescription="Wallet icon" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Current Balance"
                android:fontFamily="@font/space_grotesk_regular"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="10dp" />

            <TextView
                android:id="@+id/tvCurrentBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$500.00"
                android:fontFamily="@font/space_grotesk_bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilBalanceInput"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="Enter amount"
            app:prefixText="$"
            app:prefixTextColor="@color/accent_green"
            app:prefixTextAppearance="@style/PrefixTextStyle"
            app:boxStrokeColor="@color/input_stroke_selector"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="2dp"
            app:boxBackgroundColor="@color/surface_variant"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:hintTextColor="@color/text_secondary"
            app:counterEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBalanceAmount"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:inputType="numberDecimal"
                android:fontFamily="@font/space_grotesk_bold"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:imeOptions="actionDone"
                android:paddingStart="4dp"
                android:paddingEnd="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Balance after deposit"
                android:fontFamily="@font/space_grotesk_regular"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvBalanceAfter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$500.00"
                android:fontFamily="@font/space_grotesk_bold"
                android:textSize="18sp"
                android:textColor="@color/accent_green" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="28dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelBalance"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Cancel"
                android:fontFamily="@font/space_grotesk_medium"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1.5dp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmBalance"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Confirm"
                android:fontFamily="@font/space_grotesk_bold"
                android:textSize="15sp"
                android:textColor="@color/on_accent"
                android:backgroundTint="@color/accent_green"
                app:cornerRadius="16dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
